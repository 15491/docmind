generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  /// 用户唯一标识
  id             String          @id @default(cuid())
  /// 用户昵称
  name           String?
  /// 邮箱，全局唯一，作为登录凭证
  email          String          @unique
  /// 邮箱验证时间，null 表示未验证
  emailVerified  DateTime?
  /// 头像 URL
  image          String?
  /// 邮箱密码登录的哈希密码，OAuth 用户为 null
  passwordHash   String?
  /// 关联的 OAuth 账号列表
  accounts       Account[]
  /// 关联的登录会话列表
  sessions       Session[]
  /// 该用户创建的知识库列表
  knowledgeBases KnowledgeBase[]
  /// 注册时间
  createdAt      DateTime        @default(now())
  /// 最后更新时间
  updatedAt      DateTime        @updatedAt
}

model Account {
  /// 关联的用户 ID
  userId            String
  /// 账号类型，固定为 oauth
  type              String
  /// OAuth 提供商，如 github / google
  provider          String
  /// 提供商侧的用户唯一 ID
  providerAccountId String
  /// OAuth 刷新令牌
  refresh_token     String?
  /// OAuth 访问令牌
  access_token      String?
  /// 访问令牌过期时间戳（Unix 秒）
  expires_at        Int?
  /// 令牌类型，通常为 Bearer
  token_type        String?
  /// OAuth 授权范围
  scope             String?
  /// OpenID Connect id_token
  id_token          String?
  /// OAuth 会话状态
  session_state     String?
  /// 绑定时间
  createdAt         DateTime @default(now())
  /// 最后更新时间
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  /// 会话令牌，全局唯一
  sessionToken String   @unique
  /// 关联的用户 ID
  userId       String
  /// 会话过期时间
  expires      DateTime
  /// 创建时间
  createdAt    DateTime @default(now())
  /// 最后更新时间
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// ─── Business ────────────────────────────────────────────────────────────────

model KnowledgeBase {
  /// 知识库唯一标识
  id        String        @id @default(cuid())
  /// 知识库名称
  name      String
  /// 所属用户 ID
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 知识库下的文档列表
  documents Document[]
  /// 知识库下的对话会话列表
  sessions  ChatSession[]
  /// 创建时间
  createdAt DateTime      @default(now())
  /// 最后更新时间
  updatedAt DateTime      @updatedAt
}

model Document {
  /// 文档唯一标识
  id              String          @id @default(cuid())
  /// 原始文件名
  fileName        String
  /// 文件大小，单位字节
  fileSize        Int
  /// 文件 MIME 类型，如 application/pdf
  mimeType        String
  /// 处理状态：processing | ready | failed
  status          String          @default("processing")
  /// 所属知识库 ID
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  /// 文档分块列表
  chunks          DocumentChunk[]
  /// 上传时间
  createdAt       DateTime        @default(now())
  /// 最后更新时间
  updatedAt       DateTime        @updatedAt
}

model DocumentChunk {
  /// 分块唯一标识
  id         String                       @id @default(cuid())
  /// 分块原始文本内容
  content    String
  /// 分块在文档中的顺序索引，从 0 开始
  chunkIndex Int
  /// 文本向量，维度 2048，由智谱 AI embedding-3 生成
  embedding  Unsupported("vector(2048)")?
  /// 所属文档 ID
  documentId String
  document   Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  /// 创建时间
  createdAt  DateTime                     @default(now())
}

model ChatSession {
  /// 会话唯一标识
  id              String        @id @default(cuid())
  /// 会话标题，由首条消息自动生成
  title           String?
  /// 所属知识库 ID
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  /// 会话消息列表
  messages        Message[]
  /// 创建时间
  createdAt       DateTime      @default(now())
  /// 最后更新时间
  updatedAt       DateTime      @updatedAt
}

model Message {
  /// 消息唯一标识
  id        String      @id @default(cuid())
  /// 发送方角色：user | assistant
  role      String
  /// 消息正文
  content   String
  /// 引用来源，格式：[{ documentName, chunkIndex, content }]
  sources   Json?
  /// 所属会话 ID
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// 发送时间
  createdAt DateTime    @default(now())
}
